# =============================================
# AgroMáquinas – Modelo de variáveis de ambiente
# =============================================
# COMO USAR:
# 1. Copie este arquivo e renomeie para ".env" (com o ponto na frente)
#    No PowerShell:  copy .env.example .env
# 2. Substitua os valores pelos seus, copiados do painel da Supabase
# 3. NUNCA comite o arquivo .env no Git (ele já está no .gitignore)
# =============================================

# URL do projeto Supabase
# Onde encontrar: Painel Supabase → Project Settings → API → "Project URL"
SUPABASE_URL=https://SUBSTITUA-PELO-SEU-PROJETO.supabase.co

# Chave service_role do Supabase (PODERES TOTAIS no banco)
# Onde encontrar: Painel Supabase → Project Settings → API → "service_role" (clique em "Reveal")
# ATENÇÃO: NUNCA exponha essa chave em código de frontend (JS do navegador).
# Aqui no backend ela é segura porque o servidor não envia o .env para fora.
SUPABASE_SERVICE_KEY=eyJSUBSTITUA-PELA-SUA-SERVICE-ROLE-KEY

# Chave secreta usada pelo Flask para assinar sessões / cookies.
# Pode ser qualquer string longa e aleatória. Sugestão: gere uma
# com 64 caracteres em https://passwordsgenerator.net
SECRET_KEY=troque-isso-por-uma-string-longa-aleatoria-de-no-minimo-32-chars

# "development" liga o modo debug (mostra erros detalhados, reinicia
# automaticamente quando o código muda). Use SEMPRE "development" enquanto
# estiver aprendendo. Em produção real, troque para "production".
FLASK_ENV=development

# Porta em que o backend vai escutar. Padrão: 5000.
# Mude se a porta 5000 já estiver em uso por outro programa.
PORT=5000
